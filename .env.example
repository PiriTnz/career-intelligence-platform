# Career Intelligence Platform — environment template
# Copy to .env and fill in ALL values marked <CHANGE_ME> before starting.
# NEVER commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=cip
POSTGRES_PASSWORD=<CHANGE_ME>
DATABASE_URL=postgresql+asyncpg://cip:<CHANGE_ME>@localhost:5432/career_intel

# ── Backend ───────────────────────────────────────────────────────────────────
# Generate a secure key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<CHANGE_ME>

# Deployment environment: development | staging | production
APP_ENV=development

# CORS: comma-separated list of allowed frontend origins
# Example: CORS_ORIGINS=https://app.example.com,https://www.example.com
CORS_ORIGINS=http://localhost:3000

# ── LLM providers ─────────────────────────────────────────────────────────────
# Leave OPENAI_API_KEY blank to use local Ollama instead
OPENAI_API_KEY=

# ── Job sources (optional) ────────────────────────────────────────────────────
FRANCE_TRAVAIL_CLIENT_ID=
FRANCE_TRAVAIL_CLIENT_SECRET=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# ── n8n ───────────────────────────────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=<CHANGE_ME>

# Service account for n8n → backend API calls
# Must match a registered user in the Career Intelligence Platform database
SERVICE_ACCOUNT_EMAIL=<SERVICE_ACCOUNT_EMAIL>
SERVICE_ACCOUNT_PASSWORD=<CHANGE_ME>

# Optional: Slack or Discord incoming webhook for job alerts
# Leave blank to disable notifications
NOTIFICATION_WEBHOOK_URL=
