{
  "$schema": "http://json-schema.org/draft-07/schema",
  "description": "Unified job schema — all sources normalize to this",
  "type": "object",
  "required": ["id", "source", "url", "title", "company_name"],
  "properties": {
    "id": {
      "type": "string",
      "description": "UUID generated by system"
    },
    "source": {
      "type": "string",
      "enum": ["france_travail", "adzuna", "wttj", "hellowork", "remotive", "manual"],
      "description": "Where this job came from"
    },
    "source_id": {
      "type": "string",
      "description": "Original ID from the source"
    },
    "url": {
      "type": "string",
      "description": "Direct link to job posting — used as dedup key"
    },
    "title": {
      "type": "string",
      "description": "Job title as posted"
    },
    "company_name": {
      "type": "string"
    },
    "location": {
      "type": "string",
      "description": "City or region"
    },
    "remote": {
      "type": "string",
      "enum": ["none", "hybrid", "full"],
      "default": "none"
    },
    "contract_type": {
      "type": "string",
      "enum": ["alternance", "cdi", "cdd", "stage", "freelance", "unknown"],
      "default": "unknown"
    },
    "salary_min": {
      "type": ["integer", "null"],
      "description": "Annual salary in EUR"
    },
    "salary_max": {
      "type": ["integer", "null"]
    },
    "required_skills": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Extracted from description"
    },
    "experience_level": {
      "type": "string",
      "enum": ["junior", "mid", "senior", "unknown"],
      "default": "unknown"
    },
    "language": {
      "type": "string",
      "enum": ["fr", "en", "other"],
      "default": "fr"
    },
    "description": {
      "type": "string",
      "description": "Full job description text"
    },
    "published_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "scraped_at": {
      "type": "string",
      "format": "date-time"
    },
    "_raw": {
      "type": "object",
      "description": "Original raw data from source — kept for debugging"
    }
  },
  "examples": [
    {
      "id": "uuid-here",
      "source": "france_travail",
      "source_id": "FT-12345",
      "url": "https://candidat.francetravail.fr/offres/recherche/detail/FT-12345",
      "title": "Alternance — AI Engineer",
      "company_name": "Acme Corp",
      "location": "Lyon",
      "remote": "hybrid",
      "contract_type": "alternance",
      "salary_min": 18000,
      "salary_max": 22000,
      "required_skills": ["python", "docker", "llm"],
      "experience_level": "junior",
      "language": "fr",
      "description": "Nous recherchons...",
      "published_at": "2024-06-01T08:00:00Z",
      "scraped_at": "2024-06-02T10:00:00Z"
    }
  ]
}
